# ── Megalert API ────────────────────────────────────────────────────────────
MEGALERT_HOST=0.0.0.0
MEGALERT_PORT=5000
MEGALERT_DEBUG=false

# ── MikroTik device ──────────────────────────────────────────────────────────
MIKROTIK_HOST=<router-ip-address>
MIKROTIK_PORT=8728
MIKROTIK_USER=<routeros-username>
MIKROTIK_PASS=<routeros-password>
# LTE interface for outgoing SMS. Leave empty to use MikroTik's default interface.
MIKROTIK_SMS_PORT=lte1

# ── Authentication ────────────────────────────────────────────────────────────
# Primary Bearer token — generate with: openssl rand -hex 32
API_TOKEN=<generate-with-openssl-rand-hex-32>

# ── Validation ────────────────────────────────────────────────────────────────
# Comma-separated country calling codes (without +). Leave empty to allow all.
ALLOWED_COUNTRY_CODES=49
# Maximum SMS character length. Each part fits ~141 chars of content (145 minus
# the "X/Y " prefix). 2 parts ≈ 282 chars, 3 parts ≈ 423 chars, 4 parts ≈ 564 chars.
MAX_MESSAGE_LENGTH=480

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Note: this limit applies per Gunicorn worker. With --workers 2 the effective
# limit is RATE_LIMIT_PER_MINUTE × 2. Use --workers 1 for a single MikroTik device.
RATE_LIMIT_PER_MINUTE=10
